# ====================================================
# Application
# ====================================================
NODE_ENV=development
PORT=3000

# ====================================================
# Database
# ====================================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/nestjs_starter?schema=public"

# ====================================================
# JWT - Access Token (단기, 15분)
# 최소 32자 이상의 랜덤 문자열 사용 권장
# 생성 예시: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ====================================================
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m

# ====================================================
# JWT - Refresh Token (장기, 7일)
# Access Secret과 반드시 다른 값 사용!
# ====================================================
JWT_REFRESH_SECRET=your-super-secret-refresh-key-different-from-access-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# ====================================================
# Security
# ====================================================
BCRYPT_SALT_ROUNDS=12

# ====================================================
# CORS (허용할 프론트엔드 주소)
# ====================================================
CORS_ORIGIN=http://localhost:3000
